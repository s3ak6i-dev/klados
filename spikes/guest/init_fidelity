#!/bin/sh
# PID 1 = guest agent supervising the fidelity workload (multi-process SQLite writer).
# The agent answers CHECK queries over vsock (DB integrity + per-worker row counts).
mount -t proc proc /proc 2>/dev/null
mount -t sysfs sys /sys 2>/dev/null
mount -t tmpfs tmpfs /run 2>/dev/null
mkdir -p /run/klados
echo 0 > /run/klados/forkgen
exec /usr/bin/python3 -u /klados/guest_agent.py /usr/bin/python3 -u /fidelity_workload.py
